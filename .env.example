# Copie para .env e ajuste os valores.

# Banco — Supabase / PostgreSQL (Supabase → Connect → ORMs → Prisma).
# Codifique caracteres especiais da senha na URL (ex.: @ -> %40).
# Projetos recentes usam o host com prefixo "aws-1-".
DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-1-<regiao>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.<ref>:<senha>@aws-1-<regiao>.pooler.supabase.com:5432/postgres"

AUTH_SECRET="gere-com-openssl-rand-base64-32"
ADMIN_EMAIL="corretor@guilhermevalim.com.br"
ADMIN_SENHA="painel123"
ADMIN_NOME="Guilherme Valim"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP="5551999990000"

# Supabase API + Storage (uploads). Não é usado pelo Prisma.
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# service_role key (SECRETA). Defina para usar Supabase Storage nos uploads
# (obrigatório em produção). Vazio = uploads em disco local (apenas dev).
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET="uploads"
